  "deploymentSpec": {
    "executors": {
      "exec-finalize-run-component": {
        "container": {
          "args": [
            "--executor_input",
            "{{$}}",
            "--function_to_execute",
            "finalize_run_component"
          ],
          "command": [
            "sh",
            "-c",
            "\nif ! [ -x \"$(command -v pip)\" ]; then\n    python3 -m ensurepip || python3 -m ensurepip --user || apt-get install python3-pip\nfi\n\nPIP_DISABLE_PIP_VERSION_CHECK=1 python3 -m pip install --quiet --no-warn-script-location 'kfp==2.7.0' '--no-deps' 'typing-extensions>=3.7.4,<5; python_version<\"3.9\"'  &&  python3 -m pip install --quiet --no-warn-script-location 'google-cloud-bigquery==3.25.0' && \"$0\" \"$@\"\n",
            "sh",
            "-ec",
            "program_path=$(mktemp -d)\n\nprintf \"%s\" \"$0\" > \"$program_path/ephemeral_component.py\"\n_KFP_RUNTIME=true python3 -m kfp.dsl.executor_main                         --component_module_path                         \"$program_path/ephemeral_component.py\"                         \"$@\"\n",
            "\nimport kfp\nfrom kfp import dsl\nfrom kfp.dsl import *\nfrom typing import *\n\ndef finalize_run_component(\n    project_id: str,\n    table_id: str,\n    run_id: str,\n    period: str,\n    run_type: str,\n    triggered_by: str,\n    final_status: str,\n    notes: str,\n) -> str:\n    from datetime import datetime, timezone\n    from google.cloud import bigquery\n\n    client = bigquery.Client(project=project_id)\n    now = datetime.now(timezone.utc).isoformat()\n\n    row = {\n        \"run_id\": run_id,\n        \"period\": period,\n        \"run_type\": run_type,\n        \"status\": final_status,\n        \"started_ts\": now,\n        \"updated_ts\": now,\n        \"triggered_by\": triggered_by,\n        \"notes\": notes,\n    }\n\n    errors = client.insert_rows_json(table_id, [row])\n    print(f\"Finalize insert response: {errors}\")\n\n    if errors:\n        raise RuntimeError(f\"Failed to insert finalize row: {errors}\")\n\n    print(f\"Inserted finalize row: {row}\")\n    return final_status\n\n"
          ],
          "image": "python:3.11-slim"
        }
      },
      "exec-init-run-component": {
        "container": {
          "args": [
            "--executor_input",
            "{{$}}",
            "--function_to_execute",
            "init_run_component"
          ],
          "command": [
            "sh",
            "-c",
            "\nif ! [ -x \"$(command -v pip)\" ]; then\n    python3 -m ensurepip || python3 -m ensurepip --user || apt-get install python3-pip\nfi\n\nPIP_DISABLE_PIP_VERSION_CHECK=1 python3 -m pip install --quiet --no-warn-script-location 'kfp==2.7.0' '--no-deps' 'typing-extensions>=3.7.4,<5; python_version<\"3.9\"'  &&  python3 -m pip install --quiet --no-warn-script-location 'google-cloud-bigquery==3.25.0' && \"$0\" \"$@\"\n",
            "sh",
            "-ec",
            "program_path=$(mktemp -d)\n\nprintf \"%s\" \"$0\" > \"$program_path/ephemeral_component.py\"\n_KFP_RUNTIME=true python3 -m kfp.dsl.executor_main                         --component_module_path                         \"$program_path/ephemeral_component.py\"                         \"$@\"\n",
            "\nimport kfp\nfrom kfp import dsl\nfrom kfp.dsl import *\nfrom typing import *\n\ndef init_run_component(\n    project_id: str,\n    table_id: str,\n    run_id: str,\n    period: str,\n    run_type: str,\n    triggered_by: str,\n) -> str:\n    from datetime import datetime, timezone\n    from google.cloud import bigquery\n\n    client = bigquery.Client(project=project_id)\n    now = datetime.now(timezone.utc).isoformat()\n\n    row = {\n        \"run_id\": run_id,\n        \"period\": period,\n        \"run_type\": run_type,\n        \"status\": \"STARTED\",\n        \"started_ts\": now,\n        \"updated_ts\": now,\n        \"triggered_by\": triggered_by,\n        \"notes\": \"Run initialized by Vertex AI Pipeline\",\n    }\n\n    errors = client.insert_rows_json(table_id, [row])\n    if errors:\n        raise RuntimeError(f\"Failed to insert run control row: {errors}\")\n\n    print(f\"Inserted run control row: {row}\")\n    return run_id\n\n"
          ],
          "image": "python:3.11-slim"
        }
      },
      "exec-invoke-router-component": {
        "container": {
          "args": [
            "--executor_input",
            "{{$}}",
            "--function_to_execute",
            "invoke_router_component"
          ],
          "command": [
            "sh",
            "-c",
            "\nif ! [ -x \"$(command -v pip)\" ]; then\n    python3 -m ensurepip || python3 -m ensurepip --user || apt-get install python3-pip\nfi\n\nPIP_DISABLE_PIP_VERSION_CHECK=1 python3 -m pip install --quiet --no-warn-script-location 'kfp==2.7.0' '--no-deps' 'typing-extensions>=3.7.4,<5; python_version<\"3.9\"'  &&  python3 -m pip install --quiet --no-warn-script-location 'requests' && \"$0\" \"$@\"\n",
            "sh",
            "-ec",
            "program_path=$(mktemp -d)\n\nprintf \"%s\" \"$0\" > \"$program_path/ephemeral_component.py\"\n_KFP_RUNTIME=true python3 -m kfp.dsl.executor_main                         --component_module_path                         \"$program_path/ephemeral_component.py\"                         \"$@\"\n",
            "\nimport kfp\nfrom kfp import dsl\nfrom kfp.dsl import *\nfrom typing import *\n\ndef invoke_router_component(\n    router_url: str,\n    run_id: str,\n    period: str,\n    run_type: str,\n    triggered_by: str,\n) -> str:\n    import requests\n\n    payload = {\n        \"run_id\": run_id,\n        \"period\": period,\n        \"run_type\": run_type,\n        \"created_by\": triggered_by,\n        \"trigger_mode\": \"vertex_pipeline\"\n    }\n\n    print(f\"Calling Router: {router_url}\")\n    print(f\"Payload: {payload}\")\n\n    response = requests.post(router_url, json=payload, timeout=60)\n\n    if response.status_code != 200:\n        raise RuntimeError(f\"Router call failed: {response.status_code} {response.text}\")\n\n    print(f\"Router triggered successfully: {response.text}\")\n    return response.text\n\n"
          ],
          "image": "python:3.11-slim"
        }
      }
    }
  },
