INSERT INTO `{{ project_id }}.finance_core_dev.reconciliation_results`
(
  run_id,
  gl_id,
  bank_id,
  match_status,
  variance_amount,
  match_rule,
  reconciled_at
)
WITH gl_candidates AS (
  SELECT *
  FROM `{{ project_id }}.finance_core_dev.gl_transactions`
  WHERE booking_date BETWEEN DATE('{{ start_date }}') AND DATE('{{ end_date }}')
),
bank_candidates AS (
  SELECT *
  FROM `{{ project_id }}.finance_core_dev.bank_feeds`
  WHERE settlement_date BETWEEN DATE('{{ start_date }}') AND DATE('{{ end_date }}')
     OR settlement_date BETWEEN DATE('{{ start_date }}') AND DATE_ADD(DATE('{{ end_date }}'), INTERVAL 3 DAY)
),
candidate_pairs AS (
  SELECT
    '{{ run_id }}' AS run_id,
    g.id AS gl_id,
    b.id AS bank_id,
    'EXACT' AS match_status,
    CAST(0 AS NUMERIC) AS variance_amount,
    'exact_amount_desc_date' AS match_rule,
    CURRENT_TIMESTAMP() AS reconciled_at,
    ROW_NUMBER() OVER (
      PARTITION BY g.id
      ORDER BY ABS(DATE_DIFF(b.settlement_date, g.booking_date, DAY)), b.id
    ) AS gl_rank,
    ROW_NUMBER() OVER (
      PARTITION BY b.id
      ORDER BY ABS(DATE_DIFF(b.settlement_date, g.booking_date, DAY)), g.id
    ) AS bank_rank
  FROM gl_candidates g
  JOIN bank_candidates b
    ON g.entity = b.entity
   AND g.currency = b.currency
   AND g.amount = b.amount
   AND LOWER(TRIM(g.description)) = LOWER(TRIM(b.description))
   AND ABS(DATE_DIFF(b.settlement_date, g.booking_date, DAY)) <= 3
)
SELECT
  run_id,
  gl_id,
  bank_id,
  match_status,
  variance_amount,
  match_rule,
  reconciled_at
FROM candidate_pairs
WHERE gl_rank = 1
  AND bank_rank = 1;
